#!/bin/bash
# live-build/config/binary - Binary image configuration for T430 OS

set -e

lb config \
    --binary-images iso-hybrid \
    --iso-application "T430-OS" \
    --iso-preparer "ThinkPad T430 Optimized OS Project" \
    --iso-publisher "T430 OS Team" \
    --iso-volume "T430_OS" \
    --debian-installer false \
    --memtest memtest86+ \
    --bootappend-live "boot=live components quiet splash elevator=none iommu=soft zswap.enabled=1" \
    --chroot-filesystem ext4 \
    "${@}"

echo "✅ Binary configuration created for T430 OS"
echo "   Output: ISO Hybrid (USB bootable)"
echo "   Boot options: elevator=none iommu=soft zswap.enabled=1"
echo "   Optimized for SSD and Ivy Bridge GPU"
