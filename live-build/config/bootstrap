#!/bin/bash
# live-build/config/bootstrap - Bootstrap configuration for T430 OS

set -e

# Use Debian Bookworm (stable, lightweight)
lb config \
    --distribution bookworm \
    --mirror-bootstrap http://deb.debian.org/debian \
    --architectures amd64 \
    --linux-flavours amd64 \
    --memtest memtest86+ \
    "${@}"

echo "✅ Bootstrap configuration created for T430 OS"
echo "   Base: Debian Bookworm (amd64)"
echo "   Optimized for: Intel Ivy Bridge (T430)"
