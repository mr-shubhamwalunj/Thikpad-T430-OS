#!/bin/bash
# live-build/config/common - Common settings for T430 OS build
# NOTE: This file is sourced by live-build, NOT executed directly

# Distribution settings
export LB_DISTRIBUTION="bookworm"
export LB_MIRROR_BOOTSTRAP="http://deb.debian.org/debian"
export LB_MIRROR_CHROOT="http://deb.debian.org/debian"
export LB_MIRROR_BINARY="http://deb.debian.org/debian"

# Architecture optimized for T430 (Ivy Bridge)
export LB_ARCHITECTURE="amd64"
export LB_LINUX_FLAVOURS="amd64"

# Binary format
export LB_BINARY_IMAGES="iso-hybrid"

# ISO settings
export LB_ISO_APPLICATION="T430-OS"
export LB_ISO_PREPARER="ThinkPad T430 Optimized OS Project"
export LB_ISO_PUBLISHER="T430 OS Team"
export LB_ISO_VOLUME="T430_OS"

# Boot options for T430 hardware
export LB_BOOTAPPEND_LIVE="boot=live components quiet splash elevator=none iommu=soft zswap.enabled=1"

# Chroot settings
export LB_CHROOT_FILESYSTEM="ext4"
export LB_MEMTEST="memtest86+"

echo "T430 OS common configuration loaded"
echo "Distribution: ${LB_DISTRIBUTION}"
echo "Architecture: ${LB_ARCHITECTURE}"
echo "Boot options: ${LB_BOOTAPPEND_LIVE}"
